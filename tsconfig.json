{
  "compilerOptions": {
    "target": "ES2022",
    "module": "Node16",
    "moduleResolution": "Node16",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "forceConsistentCasingInFileNames": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "dist",
    "rootDir": ".",
    "composite": true,
    "paths": {
      "@closeclaw/shared-types": ["./packages/shared-types/src/index.ts"],
      "@closeclaw/bot-adapters": ["./packages/bot-adapters/src/index.ts"],
      "@closeclaw/gateway": ["./packages/gateway/src/index.ts"],
      "@closeclaw/cli": ["./packages/cli/src/index.ts"]
    }
  },
  "exclude": ["node_modules", "dist", "coverage", "vitest.config.ts"]
}
